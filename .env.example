# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fund_analysis
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/fund_analysis

# Redis配置
REDIS_URL=redis://localhost:6379/0

# JWT配置
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM配置 (DeepSeek)
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 阿里云大模型配置
ALIYUN_LLM_API_KEY=
ALIYUN_LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_EMBEDDING_MODEL=text-embedding-v3

# 数据源配置
TUSHARE_TOKEN=

# 短信服务配置 (阿里云)
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# 应用配置
APP_NAME=FundAI
APP_VERSION=1.0.0
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# 限流配置
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# RAG 配置
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODE=aliyun
EMBEDDING_MODEL_NAME=text-embedding-v3
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
