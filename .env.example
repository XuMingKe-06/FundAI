# =============================================
# FundAI 环境配置示例文件
# 多智能体场外基金分析决策系统
# 
# 使用说明:
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 根据实际环境修改配置值
# =============================================

# =============================================
# 1. 应用基础配置
# =============================================
APP_NAME=FundAI
APP_VERSION=1.0.0
DEBUG=true

# =============================================
# 2. 数据库配置 (PostgreSQL)
# 格式: postgresql+asyncpg://用户名:密码@主机:端口/数据库名
# =============================================
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/fund_analysis
DATABASE_SYNC_URL=postgresql://postgres:your_password@localhost:5432/fund_analysis

# =============================================
# 3. Redis 配置
# 格式: redis://主机:端口/数据库编号
# 如需密码: redis://:password@host:port/db
# =============================================
REDIS_URL=redis://localhost:6379/0

# =============================================
# 4. JWT 认证配置
# 警告: 生产环境必须修改 JWT_SECRET_KEY 为强随机字符串
# 生成方式: openssl rand -hex 32
# =============================================
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================
# 5. LLM 配置 (阿里云百炼)
# API Key 优先级: DASHSCOPE_API_KEY > ALIYUN_LLM_API_KEY
# 获取地址: https://dashscope.console.aliyun.com/
# =============================================
LLM_PROVIDER=aliyun

# 阿里云百炼 API Key (必须配置)
# 可通过系统环境变量 DASHSCOPE_API_KEY 设置，或直接在此配置
DASHSCOPE_API_KEY=your-dashscope-api-key-here
ALIYUN_LLM_API_KEY=your-aliyun-llm-api-key-here

# 阿里云百炼 API 地址
ALIYUN_LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM 模型配置
# 推荐模型: qwen3-vl-235b-a22b-thinking (深度思考)
# 其他可选: qwen-plus, qwen-turbo, qwen-max
ALIYUN_LLM_MODEL=qwen3-vl-235b-a22b-thinking

# Embedding 模型配置
ALIYUN_EMBEDDING_MODEL=text-embedding-v3

# =============================================
# 6. 数据源配置
# =============================================

# Tushare Pro API Token (可选)
# 获取地址: https://tushare.pro/
TUSHARE_TOKEN=your-tushare-token-here

# =============================================
# 7. 阿里云短信服务配置 (可选)
# 用于发送验证码等短信通知
# 获取地址: https://dysms.console.aliyun.com/
# =============================================
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_SMS_SIGN_NAME=FundAI
ALIYUN_SMS_TEMPLATE_CODE=your-template-code

# =============================================
# 8. CORS 跨域配置
# 多个源用逗号分隔
# =============================================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# =============================================
# 9. 限流配置
# =============================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# =============================================
# 10. RAG 配置 (检索增强生成)
# =============================================

# Chroma 向量数据库持久化目录
CHROMA_PERSIST_DIR=./data/chroma

# Embedding 配置
# 模式: local (本地模型), api (OpenAI API), aliyun (阿里云 API)
EMBEDDING_MODE=aliyun
EMBEDDING_MODEL_NAME=text-embedding-v3

# RAG 检索参数
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
