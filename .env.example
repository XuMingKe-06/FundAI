# =============================================
# FundAI 环境配置示例文件
# 多智能体场外基金分析决策系统
#
# 使用说明:
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 根据实际环境修改配置值
#
# 注意: LLM 配置（API URL、API Key、模型名称等）
# 现在通过前端设置页面管理，存储在 data/config.json 中
# =============================================

# =============================================
# 1. 应用基础配置
# =============================================
APP_NAME=FundAI
APP_VERSION=1.0.0
DEBUG=true

# =============================================
# 2. 数据库配置 (PostgreSQL)
# 格式: postgresql+asyncpg://用户名:密码@主机:端口/数据库名
# =============================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fundai

# =============================================
# 3. Redis 缓存配置
# 格式: redis://主机:端口/数据库编号
# =============================================
REDIS_URL=redis://localhost:6379/0

# =============================================
# 4. 数据源配置
# =============================================

# Tushare Pro API Token (可选)
# 获取地址: https://tushare.pro/
TUSHARE_TOKEN=your-tushare-token-here

# =============================================
# 5. CORS 跨域配置
# 多个源用逗号分隔
# =============================================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# =============================================
# 6. RAG 配置 (检索增强生成)
# =============================================

# Chroma 向量数据库持久化目录
CHROMA_PERSIST_DIR=./data/chroma

# Embedding 配置
# 模式: local (本地模型), api (远程 API)
EMBEDDING_MODE=api
EMBEDDING_MODEL_NAME=

# RAG 检索参数
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
